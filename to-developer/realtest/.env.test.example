# ARIS dedicated real-machine test container.
# Copy to to-developer/realtest/.env.test and fill absolute host paths.

TEST_USERNAME=aris-test
TEST_UID=1000
TEST_GID=1000
TEST_ARIS_BRANCH=stable

# Required host paths.
TEST_FRAMEWORK_PATH=[你的framework位置]
TEST_PROJECTS_PATH=[你的实机测试项目临时目录]
TEST_LOGS_PATH=[你的实机测试日志目录]

# Optional host paths. Leave as /tmp placeholders if not needed.
TEST_DATASETS_PATH=/tmp/aris-empty-datasets
TEST_PRETRAINED_PATH=/tmp/aris-empty-pretrained

# Optional API/proxy settings copied into the test container.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost
http_proxy=
https_proxy=
no_proxy=127.0.0.1,localhost
GIT_HTTP_PROXY=
GIT_HTTPS_PROXY=

# Keep update checks off by default in tests. Real-machine tests should not
# silently mutate the framework checkout.
ARIS_AUTO_CHECK_UPDATE=0
ARIS_UPDATE_CHECK_INTERVAL=1d
ARIS_UPDATE_CHECK_TIMEOUT=10s

# Test identity and command.
ARIS_REALTEST_NAME=smoke
# Empty = default smoke: versions + ARIS CLI doctor/init/update smoke.
# Example:
# ARIS_REALTEST_COMMAND=python -m pytest tests/test_feishu_transport_docs.py -q
ARIS_REALTEST_COMMAND=
