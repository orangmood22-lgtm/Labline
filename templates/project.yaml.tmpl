# project.yaml — ARIS 科研项目元数据
# 由 `aris project init` 自动生成，手动编辑也 OK

schema_version: 1

project:
  name: "{PROJECT_NAME}"
  direction: "{RESEARCH_DIRECTION}"
  size: "full"              # full | small
  language: "zh"            # zh | en
  created: "{DATE}"
  author: "{USER}"

# Git 配置 — $sync 读这个
git:
  auto_commit: true         # sync 时自动 commit
  remote: ""                # Gitea URL, 留空 = 纯本地
  branch: "main"

# 远程 GPU 服务器 — $sync deploy 和 $leader Phase 3 读这个
servers: []                  # no remote servers by default
# Example:
# servers:
#   - name: "4090x4"
#     host: "4090x4-ai-original-22"
#     path: "[服务器上的项目位置]/{PROJECT_NAME}"
#     conda_env: "/path/to/conda/env"
#     gpus: [0, 2, 3]

# 框架路径 — $framework-update 读这个
framework:
  path: "{FRAMEWORK_PATH}"
  repo: "{FRAMEWORK_REPO}"
  version: "{FRAMEWORK_VERSION}"
  commit: "{FRAMEWORK_COMMIT}"
  recorded_at: "{FRAMEWORK_RECORDED_AT}"

# 项目级框架 override 注册表（集中管理）
# 允许的项目本地定制条目，每个条目必须声明原因、负责人和预计迁移/删除日期
overrides:
  registry: "overrides/"   # 相对于项目根目录
  entries: []
  # - name: "custom-skill-x"
  #   why: "解决项目特定数据集格式问题"
  #   owner: "alice"
  #   created_at: "2026-06-10"
  #   promote_or_delete_by: "2026-09-10"
  #   type: "skill"         # skill | template | tool | config

# 数据集 — 容器内共享路径
data:
  shared: "/aris/shared/datasets"
  project: "./data"         # 项目私有数据

# 同步排除 — $sync 和 rsync 用
sync_exclude:
  - "outputs/"
  - "wandb/"
  - "*.tar.gz"
  - "*.pth"
  - "*.pt"
  - "__pycache__/"
  - ".pytest_cache/"
  - "datasets/"
