# API 配置机制
# 优先级: 个人 > 项目 > 组默认
# 位置: ~/.labline/api.yaml (个人) 或 /lane/framework/deploy/api-default.yaml (组默认)

# Codex-first 默认。Claude Code 仅作为兼容客户端。
active: "openai"

providers:
  openai:
    # Codex 主入口 / Leader 默认
    base_url: "https://api.openai.com/v1"
    api_key: ""             # 留空 = 读 OPENAI_API_KEY
    model: "gpt-5.5"
    wire_api: "responses"

  openai-gpt54:
    # Planner / Writer / Reviewer 默认
    base_url: "https://api.openai.com/v1"
    api_key: ""
    model: "gpt-5.4"
    wire_api: "responses"

  openai-gpt54-mini:
    # Coder / Deployer 默认
    base_url: "https://api.openai.com/v1"
    api_key: ""
    model: "gpt-5.4-mini"
    wire_api: "responses"

  anthropic:
    # Claude Code 兼容
    base_url: "https://api.anthropic.com"
    api_key: ""             # 留空 = 读环境变量 ANTHROPIC_API_KEY
    model: "claude-sonnet-4-20250514"

  anthropic-proxy:
    # 中转站
    base_url: "https://your-proxy.com/anthropic"
    api_key: ""
    model: "claude-sonnet-4-20250514"

  openai-proxy:
    # 中转 (如 how88.top)
    base_url: "https://how88.top/v1"
    api_key: ""
    model: "gpt-5.5"
    wire_api: "responses"

role_defaults:
  leader:
    provider: "openai"
    model: "gpt-5.5"
  planner:
    provider: "openai-gpt54"
    model: "gpt-5.4"
  reviewer:
    provider: "openai-gpt54"
    model: "gpt-5.4"
  writer:
    provider: "openai-gpt54"
    model: "gpt-5.4"
  coder:
    provider: "openai-gpt54-mini"
    model: "gpt-5.4-mini"
  deployer:
    provider: "openai-gpt54-mini"
    model: "gpt-5.4-mini"

# VPN/代理 — 容器内自动设
proxy:
  enabled: false
  http: ""                  # e.g. "http://host.docker.internal:7890"
  https: ""
  no_proxy: "127.0.0.1,localhost,10.*,172.16.*,192.168.*"
