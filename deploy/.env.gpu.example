# ARIS GPU Deployment — Environment Variables
# Copy to .env and fill in your values
#
# Usage: docker compose -f docker-compose.gpu.yaml up -d

# ─── User ────────────────────────────────────────────────────────────────────
USERNAME=researcher
USER_UID=1000
USER_GID=1000

# ─── ARIS Framework Branch ───────────────────────────────────────────────────
ARIS_BRANCH=orangmood-tripartite-night-20260512

# ─── API Keys ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=

# ─── Proxy (leave empty if direct) ──────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost
# Keep lowercase variants too. Some CLIs/libraries only read lowercase names.
http_proxy=
https_proxy=
no_proxy=127.0.0.1,localhost

# Optional git proxy for the host/container. Prefer env vars first; set git proxy
# only when git still cannot reach GitHub.
GIT_HTTP_PROXY=
GIT_HTTPS_PROXY=

# ─── Feishu/Lark bridge (optional) ───────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ID=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_ENABLE_WS=0
BRIDGE_PORT=5000
ARIS_PROJECT_ROOT=/aris/framework
ARIS_FEISHU_CONTROL_ROOT=

# ─── GPU ─────────────────────────────────────────────────────────────────────
# "all" = use all GPUs; "0,1" = specific GPUs
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=

# ─── Paths on host ──────────────────────────────────────────────────────────
# Framework checkout
FRAMEWORK_PATH=/data/aris/aris-framework
# Optional dev framework checkout. Leave empty if not using aris-dev.
DEV_FRAMEWORK_PATH=/data/aris/aris-dev
# Project directory
PROJECT_PATH=/data/aris/projects
# Datasets shared by containers/projects
DATASETS_PATH=/data/datasets
# Pretrained models (optional)
PRETRAINED_PATH=/data/pretrained
# SSH keys directory
SSH_PATH=/home/researcher/.ssh
