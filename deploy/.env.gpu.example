# ARIS GPU Deployment — Environment Variables
# Copy to .env and fill in your values
#
# Usage: docker compose -f docker-compose.gpu.yaml up -d

# ─── User ────────────────────────────────────────────────────────────────────
USERNAME=researcher
USER_UID=1000
USER_GID=1000

# ─── ARIS Framework Branch ───────────────────────────────────────────────────
ARIS_BRANCH=stable

# ─── API Keys ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=

# ─── Proxy (leave empty if direct) ──────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost
# Keep lowercase variants too. Some CLIs/libraries only read lowercase names.
http_proxy=
https_proxy=
no_proxy=127.0.0.1,localhost

# Optional git proxy for the host/container. Prefer env vars first; set git proxy
# only when git still cannot reach GitHub.
GIT_HTTP_PROXY=
GIT_HTTPS_PROXY=

# ─── Framework update check ─────────────────────────────────────────────────
# Default: check for framework updates when the container starts, but do not pull.
ARIS_AUTO_CHECK_UPDATE=1
ARIS_UPDATE_CHECK_INTERVAL=1d
ARIS_UPDATE_CHECK_TIMEOUT=10s

# ─── Feishu/Lark bridge (optional) ───────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ID=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_ENABLE_WS=0
BRIDGE_PORT=5000
ARIS_PROJECT_ROOT=/aris/framework
ARIS_FEISHU_CONTROL_ROOT=

# ─── GPU ─────────────────────────────────────────────────────────────────────
# "all" = use all GPUs; "0,1" = specific GPUs
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=

# ─── Paths on host ──────────────────────────────────────────────────────────
# Replace placeholders with absolute host paths. These paths do not need to be
# under the same parent directory.
# Framework checkout
FRAMEWORK_PATH=[你的framework位置]
# Optional dev framework checkout. If you keep docker-compose.gpu.yaml unchanged,
# set this to an existing absolute path. To disable it, remove/comment that mount.
DEV_FRAMEWORK_PATH=[你的dev framework位置]
# Project workspace
PROJECT_PATH=[你的项目工作区]
# Datasets shared by containers/projects
DATASETS_PATH=[你的数据集目录]
# Pretrained models/cache
PRETRAINED_PATH=[你的预训练模型目录]
# SSH keys directory
SSH_PATH=[你的SSH目录]
