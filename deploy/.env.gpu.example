# LABLINE GPU Deployment — Environment Variables
# Copy to .env and fill in your values
#
# Usage: docker compose -f docker-compose.gpu.yaml up -d

# ─── User ────────────────────────────────────────────────────────────────────
USERNAME=researcher
USER_UID=1000
USER_GID=1000

# ─── LABLINE Framework Branch ───────────────────────────────────────────────────
LABLINE_BRANCH=stable

# Prebuilt GPU image used by docker-compose.gpu.image.yaml. Keep this pinned to
# a release/candidate tag in real deployments; avoid using latest.
LABLINE_GPU_IMAGE=ghcr.io/your-org/labline-gpu:v0.1.0-cuda128

# ─── Model providers ────────────────────────────────────────────────────────
# Do not put API keys here. Configure Codex/Claude providers inside the
# container with cc-switch-cli after first login.

# ─── Proxy (default on; set LABLINE_PROXY_ENABLED=0 to disable) ─────────────
# docker-compose.gpu.yaml uses host network, so 127.0.0.1 points to the host.
# Change PROXY_PORT to your Clash/V2Ray/mihomo HTTP proxy port.
LABLINE_PROXY_ENABLED=1
PROXY_PORT=7890
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=127.0.0.1,localhost
# Keep lowercase variants too. Some CLIs/libraries only read lowercase names.
http_proxy=http://127.0.0.1:7890
https_proxy=http://127.0.0.1:7890
no_proxy=127.0.0.1,localhost
# Do not set ALL_PROXY/all_proxy for Labline containers. Some Node SDK paths
# treat it differently from HTTP_PROXY/HTTPS_PROXY and may fail with socket hang up.

# Optional git proxy for the host/container. Prefer env vars first; set git proxy
# only when git still cannot reach GitHub.
GIT_HTTP_PROXY=
GIT_HTTPS_PROXY=

# ─── Framework update check ─────────────────────────────────────────────────
# Default: check for framework updates when the container starts, but do not pull.
LABLINE_AUTO_CHECK_UPDATE=1
LABLINE_UPDATE_CHECK_INTERVAL=1d
LABLINE_UPDATE_CHECK_TIMEOUT=10s

# ─── Feishu/Lark bridge (optional) ───────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ID=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_ENABLE_WS=0
BRIDGE_PORT=5000
LABLINE_PROJECT_ROOT=/labline/framework
LABLINE_FEISHU_CONTROL_ROOT=

# ─── GPU ─────────────────────────────────────────────────────────────────────
# "all" = use all GPUs; "0,1" = specific GPUs
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=

# ─── Paths on host ──────────────────────────────────────────────────────────
# Replace placeholders with absolute host paths. These paths do not need to be
# under the same parent directory.
# Framework checkout
FRAMEWORK_PATH=[你的framework位置]
# Optional dev framework checkout. If you keep docker-compose.gpu.yaml unchanged,
# set this to an existing absolute path. To disable it, remove/comment that mount.
DEV_FRAMEWORK_PATH=[你的dev framework位置]
# Project workspace
PROJECT_PATH=[你的项目工作区]
# Datasets shared by containers/projects
DATASETS_PATH=[你的数据集目录]
# Pretrained models/cache
PRETRAINED_PATH=[你的预训练模型目录]
# SSH keys directory
SSH_PATH=[你的SSH目录]
