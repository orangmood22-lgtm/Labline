# ARIS Docker Compose Environment Variables
# Copy to .env and fill in your values

# ─── Users ────────────────────────────────────────────────────────────────────
USER1_NAME=zhangsan
USER1_UID=1001
USER1_GID=1001
USER1_SSH=~/.ssh/user1

USER2_NAME=lisi
USER2_UID=1002
USER2_GID=1002
USER2_SSH=~/.ssh/user2

# ─── API Keys (group-level, users can override inside container) ──────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=

# ─── Proxy (leave empty if direct connection works) ───────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,gitea

# ─── Paths on host ───────────────────────────────────────────────────────────
DATASETS_PATH=/data/shared/datasets
