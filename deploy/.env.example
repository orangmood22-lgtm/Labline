# LABLINE Docker Compose Environment Variables
# Copy to .env and fill in your values

# ─── Users ────────────────────────────────────────────────────────────────────
# Each USERn block maps to one long-running researcher container.
USER1_NAME=zhangsan
USER1_UID=1001
USER1_GID=1001
USER1_SSH=~/.ssh/user1
USER1_FRAMEWORK_PATH=[你的LABLINE总目录]/users/zhangsan/framework
USER1_PROJECTS_PATH=[你的LABLINE总目录]/users/zhangsan/projects
USER1_STATE_PATH=[你的LABLINE总目录]/users/zhangsan/.labline   # 挂到容器用户 home 下的 ~/.labline

USER2_NAME=lisi
USER2_UID=1002
USER2_GID=1002
USER2_SSH=~/.ssh/user2
USER2_FRAMEWORK_PATH=[你的LABLINE总目录]/users/lisi/framework
USER2_PROJECTS_PATH=[你的LABLINE总目录]/users/lisi/projects
USER2_STATE_PATH=[你的LABLINE总目录]/users/lisi/.labline   # 挂到容器用户 home 下的 ~/.labline

# ─── Model providers ────────────────────────────────────────────────────────
# Do not put API keys here. Each user configures Codex/Claude providers inside
# their own container with cc-switch-cli.

# ─── Proxy (default on; set LABLINE_PROXY_ENABLED=0 to disable) ──────────────
# Containers use host network by default, so 127.0.0.1 points to the host.
# Change PROXY_PORT to your Clash/V2Ray/mihomo HTTP proxy port.
LABLINE_PROXY_ENABLED=1
PROXY_PORT=7890
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=127.0.0.1,localhost,gitea
# Keep lowercase variants too. Some CLIs/libraries only read lowercase names.
http_proxy=http://127.0.0.1:7890
https_proxy=http://127.0.0.1:7890
no_proxy=127.0.0.1,localhost,gitea
# Do not set ALL_PROXY/all_proxy for Labline containers. Some Node SDK paths
# treat it differently from HTTP_PROXY/HTTPS_PROXY and may fail with socket hang up.

# Optional git proxy. Prefer HTTP_PROXY/HTTPS_PROXY first; set these only when
# git still cannot reach GitHub.
GIT_HTTP_PROXY=
GIT_HTTPS_PROXY=

# ─── Framework update check ─────────────────────────────────────────────────
# Default: check for framework updates when the container starts, but do not pull.
LABLINE_AUTO_CHECK_UPDATE=1
LABLINE_UPDATE_CHECK_INTERVAL=1d
LABLINE_UPDATE_CHECK_TIMEOUT=10s

# ─── Feishu/Lark bridge (optional) ───────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ID=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_ENABLE_WS=0
BRIDGE_PORT=5000
LABLINE_PROJECT_ROOT=/labline/framework
LABLINE_FEISHU_CONTROL_ROOT=

# ─── Paths on host ───────────────────────────────────────────────────────────
LABLINE_ROOT=[你的LABLINE总目录]
DATASETS_PATH=[你的LABLINE总目录]/shared/datasets
PRETRAINED_PATH=[你的LABLINE总目录]/shared/pretrained
DOWNLOADS_PATH=[你的LABLINE总目录]/shared/downloads
