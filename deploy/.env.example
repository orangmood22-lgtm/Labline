# ARIS Docker Compose Environment Variables
# Copy to .env and fill in your values

# ─── Users ────────────────────────────────────────────────────────────────────
# Each USERn block maps to one long-running researcher container.
USER1_NAME=zhangsan
USER1_UID=1001
USER1_GID=1001
USER1_SSH=~/.ssh/user1
USER1_FRAMEWORK_PATH=[你的ARIS总目录]/users/zhangsan/framework
USER1_PROJECTS_PATH=[你的ARIS总目录]/users/zhangsan/projects
USER1_STATE_PATH=[你的ARIS总目录]/users/zhangsan/.aris

USER2_NAME=lisi
USER2_UID=1002
USER2_GID=1002
USER2_SSH=~/.ssh/user2
USER2_FRAMEWORK_PATH=[你的ARIS总目录]/users/lisi/framework
USER2_PROJECTS_PATH=[你的ARIS总目录]/users/lisi/projects
USER2_STATE_PATH=[你的ARIS总目录]/users/lisi/.aris

# ─── API Keys (group-level, users can override inside container) ──────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=

# ─── Proxy (leave empty if direct connection works) ───────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,gitea
# Keep lowercase variants too. Some CLIs/libraries only read lowercase names.
http_proxy=
https_proxy=
no_proxy=127.0.0.1,localhost,gitea

# Optional git proxy. Prefer HTTP_PROXY/HTTPS_PROXY first; set these only when
# git still cannot reach GitHub.
GIT_HTTP_PROXY=
GIT_HTTPS_PROXY=

# ─── Framework update check ─────────────────────────────────────────────────
# Default: check for framework updates when the container starts, but do not pull.
ARIS_AUTO_CHECK_UPDATE=1
ARIS_UPDATE_CHECK_INTERVAL=1d
ARIS_UPDATE_CHECK_TIMEOUT=10s

# ─── Feishu/Lark bridge (optional) ───────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ID=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_ENABLE_WS=0
BRIDGE_PORT=5000
ARIS_PROJECT_ROOT=/aris/framework
ARIS_FEISHU_CONTROL_ROOT=

# ─── Paths on host ───────────────────────────────────────────────────────────
ARIS_ROOT=[你的ARIS总目录]
DATASETS_PATH=[你的ARIS总目录]/shared/datasets
PRETRAINED_PATH=[你的ARIS总目录]/shared/pretrained
DOWNLOADS_PATH=[你的ARIS总目录]/shared/downloads
