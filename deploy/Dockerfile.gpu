# LABLINE Research Framework — GPU Container Image
# Full GPU support: CUDA 12.8 + PyTorch + Claude Code + Codex CLI
# Base: nvidia/cuda:12.8.0-devel-ubuntu22.04
#
# Build:  docker build -f deploy/Dockerfile.gpu -t labline-gpu .
# Run:    docker run --gpus all -it labline-gpu

FROM nvidia/cuda:12.8.0-devel-ubuntu22.04

LABEL maintainer="LABLINE Framework"
LABEL description="AI Research Infrastructure — GPU-enabled container"

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# CUDA env (container inherits host driver, toolkit from image)
ENV CUDA_HOME=/usr/local/cuda
ENV PATH="${CUDA_HOME}/bin:${PATH}"
ENV LD_LIBRARY_PATH="${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}"

ARG BUILD_HTTP_PROXY=
ARG BUILD_HTTPS_PROXY=
ENV http_proxy="${BUILD_HTTP_PROXY}"
ENV https_proxy="${BUILD_HTTPS_PROXY}"
ENV HTTP_PROXY="${BUILD_HTTP_PROXY}"
ENV HTTPS_PROXY="${BUILD_HTTPS_PROXY}"
ENV all_proxy=
ENV ALL_PROXY=

# ─── Fix apt sources (CUDA devel images strip Ubuntu repos) ─────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && rm -f /etc/apt/sources.list.d/cuda*.list /etc/apt/apt.conf.d/*proxy* \
    && sed -i '/http_proxy/d' /etc/environment \
    && sed -i '/https_proxy/d' /etc/environment \
    && echo "deb http://archive.ubuntu.com/ubuntu jammy main restricted universe multiverse" > /etc/apt/sources.list \
    && echo "deb http://archive.ubuntu.com/ubuntu jammy-updates main restricted universe multiverse" >> /etc/apt/sources.list \
    && echo "deb http://archive.ubuntu.com/ubuntu jammy-security main restricted universe multiverse" >> /etc/apt/sources.list \
    && apt-get update

# ─── Base system packages ───────────────────────────────────────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && apt-get install -y --no-install-recommends \
    ca-certificates gnupg software-properties-common \
    curl wget git git-lfs openssh-client rsync tmux vim nano htop \
    sudo jq tree unzip \
    build-essential cmake ninja-build \
    libgl1-mesa-glx libglib2.0-0 libsm6 libxext6 libxrender-dev \
    && rm -rf /var/lib/apt/lists/*

# ─── Python (Ubuntu Jammy distribution package) ─────────────────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
    python3 python3-venv python3-dev python3-distutils python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install pip and provide the python command expected by experiment scripts.
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3 1 \
    && python3 -m pip install --upgrade pip setuptools wheel

# ─── Node.js (for Claude Code + Codex CLI) ───────────────────────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ─── Claude Code ─────────────────────────────────────────────────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && npm install -g @anthropic-ai/claude-code

# ─── Codex CLI ───────────────────────────────────────────────────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && npm install -g @openai/codex

# ─── CC-Switch CLI (API provider management) ────────────────────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && curl -fsSL https://github.com/SaladDay/cc-switch-cli/releases/latest/download/install.sh | bash \
    || (curl -LO https://github.com/saladday/cc-switch-cli/releases/latest/download/cc-switch-cli-linux-x64-musl.tar.gz \
        && tar -xzf cc-switch-cli-linux-x64-musl.tar.gz \
        && mv cc-switch /usr/local/bin/ \
        && rm -f cc-switch-cli-linux-x64-musl.tar.gz)

# ─── PyTorch + GPU stack ────────────────────────────────────────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && pip install --no-cache-dir \
    torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu128

# ─── Python scientific + ML stack ───────────────────────────────────────────
RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && pip install --no-cache-dir \
    pyyaml requests matplotlib numpy scipy pandas \
    wandb tensorboard \
    opencv-python-headless pillow scikit-learn tqdm \
    einops timm transformers accelerate

# ─── Directory structure ─────────────────────────────────────────────────────
RUN mkdir -p /labline/framework /labline/projects /labline/shared/datasets /labline/shared/pretrained

# ─── User setup (non-root) ───────────────────────────────────────────────────
ARG USERNAME=researcher
ARG UID=1000
ARG GID=1000

RUN groupadd -g ${GID} ${USERNAME} 2>/dev/null || true \
    && useradd -m -u ${UID} -g ${GID} -s /bin/bash ${USERNAME} 2>/dev/null || true \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER ${USERNAME}
WORKDIR /home/${USERNAME}

# ─── LABLINE framework clone ────────────────────────────────────────────────────
ARG LABLINE_REPO=https://github.com/orangmood22-lgtm/Labline.git
ARG LABLINE_BRANCH=orangmood-tripartite-night-20260512

RUN export http_proxy="${BUILD_HTTP_PROXY}" \
    && export https_proxy="${BUILD_HTTPS_PROXY}" \
    && export HTTP_PROXY="${BUILD_HTTP_PROXY}" \
    && export HTTPS_PROXY="${BUILD_HTTPS_PROXY}" \
    && export all_proxy= \
    && export ALL_PROXY= \
    && git clone --depth 1 -b ${LABLINE_BRANCH} ${LABLINE_REPO} /labline/framework || true

# ─── Config directories ─────────────────────────────────────────────────────
RUN mkdir -p ~/.claude ~/.codex ~/.labline ~/.ssh \
    && chmod 700 ~/.ssh

# ─── Default API config ─────────────────────────────────────────────────────
COPY templates/api-config.yaml.tmpl /home/${USERNAME}/.labline/api.yaml

# ─── Entrypoint ──────────────────────────────────────────────────────────────
COPY deploy/entrypoint.sh /usr/local/bin/entrypoint.sh
USER root
RUN chmod +x /usr/local/bin/entrypoint.sh
USER ${USERNAME}

# ─── Verify GPU stack ───────────────────────────────────────────────────────
RUN python3 -c "import torch; print(f'PyTorch {torch.__version__}, CUDA available: {torch.cuda.is_available()}')"

ENV http_proxy=
ENV https_proxy=
ENV HTTP_PROXY=
ENV HTTPS_PROXY=
ENV all_proxy=
ENV ALL_PROXY=

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
