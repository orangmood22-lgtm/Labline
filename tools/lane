            cwd=working_project,
            env=env,
            checks=checks,
        )
        status_payload = json.loads(status_result.stdout)
        if status_payload.get("source_counts", {}).get("runtime_tasks", 0) < 1:
            checks[-1]["status"] = "fail"
            checks[-1]["details"]["reason"] = "runtime_tasks not aggregated"
            raise RuntimeError("status_json did not aggregate runtime task")

        now = args.now or datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
