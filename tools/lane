    base_url = provider.get("base_url")
    api_key_env = provider.get("api_key_env")
    effort = role.get("reasoning_effort") or defaults.get("reasoning_effort", "medium")
    return role, provider_name, provider, transport, model, base_url, api_key_env, effort


def cmd_dev_workflow_start(args: argparse.Namespace) -> int:
    framework = resolve_labline_repo(args)
    data = load_dev_runtime_config(init=True)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    workflow_id = f"{stamp}-{sanitize_slug(args.task)}"
    workflow_dir = dev_workflow_log_root(framework) / workflow_id
    tasks_dir = workflow_dir / "tasks"
    evidence_dir = workflow_dir / "evidence"
    progress_dir = workflow_dir / "progress"
    questions_dir = workflow_dir / "questions"
    tasks_dir.mkdir(parents=True, exist_ok=False)
    evidence_dir.mkdir(parents=True, exist_ok=True)
    progress_dir.mkdir(parents=True, exist_ok=True)
    questions_dir.mkdir(parents=True, exist_ok=True)
    files = args.file or []
    child_roles = args.role or ["dev-worker", "dev-realtest"]
    seen_roles: set[str] = set()
    child_roles = [role for role in child_roles if not (role in seen_roles or seen_roles.add(role))]
    next_check_at = dev_workflow_next_check(args.next_check_in)

    role_task_files: dict[str, str] = {}
    workflow_section = f"""## Dev Workflow

workflow_id: {workflow_id}
workflow_dir: {workflow_dir}
evidence_dir: {evidence_dir}
progress_dir: {progress_dir}
questions_dir: {questions_dir}
child_roles: {', '.join(child_roles) if child_roles else '<none>'}
next_check_at: {next_check_at}

Write role evidence to `evidence/<role>.md`. Dev Leader reads those files before summarizing maintainer-facing status.
Before `next_check_at`, every active role must update `progress/<role>.md` through `lane dev workflow update ...`, even when blocked or no work was completed.
Record every question, ambiguity, missing decision, or environment uncertainty with `lane dev workflow question ...` as soon as it appears.
"""
    leader_role, provider_name, _provider, transport, model, base_url, api_key_env, effort = runtime_binding_for_role(data, "dev-leader")
    leader_task = f"""Coordinate this Labline developer workflow.

Original maintainer request:
{args.task}

Child roles:
{chr(10).join(f"- {role}" for role in child_roles) if child_roles else "- [none]"}

Expected output:
- a clear task split
- evidence requirements for each child role
- final risk summary after evidence exists
"""
    leader_prompt = render_runtime_task_prompt(
        "dev-leader",
        leader_task,
        provider_name,
        transport,
        model,
        base_url,
        api_key_env,
        effort,
        leader_role,
        files,
        [workflow_section],
    )
    leader_task_file = tasks_dir / "dev-leader.md"
