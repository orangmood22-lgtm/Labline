def sanitize_slug(value: str, limit: int = 48) -> str:
    slug = "".join(ch.lower() if ch.isalnum() else "-" for ch in value).strip("-")
    while "--" in slug:
        slug = slug.replace("--", "-")
    return (slug or "task")[:limit].strip("-") or "task"


def slug_from_text(text: str) -> str:
    first_line = next((line.strip() for line in text.splitlines() if line.strip()), "")
    if not first_line:
        return "task"
    return sanitize_slug(first_line)


def register_project(project: Path) -> None:
    data = load_registry()
    projects = set(data.get("projects", []))
    projects.add(str(project.resolve()))
    data["projects"] = sorted(projects)
    save_registry(data)


def unregister_project(project: Path) -> None:
    data = load_registry()
    target = str(project.resolve())
    data["projects"] = [p for p in data.get("projects", []) if str(Path(p).expanduser().resolve()) != target]
    save_registry(data)


