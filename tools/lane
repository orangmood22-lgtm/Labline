    env["LABLINE_WORKSPACE"] = str(workspace)
    lane_bin = Path(__file__).resolve()
    remote_observation = framework / "tools" / "labline_remote_observation.py"

    try:
        if args.in_place:
            append_debug_check(checks, "prepare_work_project", "pass", {"mode": "in_place"})
        else:
            if working_project.exists():
                shutil.rmtree(working_project)
            copy_project_for_runtime_smoke(source_project, working_project)
            append_debug_check(checks, "prepare_work_project", "pass", {"mode": "copy", "ignored_heavy_paths": True})

        run_debug_subprocess(
            "project_update",
