    return Path(path or ".").expanduser().resolve()


def install_clients(project: Path, framework: Path) -> list[str]:
    clients: list[str] = []
    install = framework / "tools" / "install_labline.sh"
    codex = framework / "tools" / "install_labline_codex.sh"
    if install.exists():
        run(["bash", str(install), str(project), "--labline-repo", str(framework), "--quiet", "--no-doc"])
        clients.append("claude")
    if codex.exists():
        run(["bash", str(codex), str(project), "--labline-repo", str(framework), "--quiet", "--no-doc"])
        clients.append("codex")
    return clients


def migrate_legacy_project_manifest(project: Path, framework: Path) -> bool:
    target = project / STATE_DIR_NAME / "manifest.json"
    if target.exists():
        return False
    legacy = project / LEGACY_STATE_DIR_NAME / "manifest.json"
    if not legacy.exists():
        return False
    try:
        payload = json.loads(legacy.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        payload = {"schema_version": 1}
    payload.setdefault("schema_version", 1)
    payload["migrated_from"] = "ARIS"
    payload["migrated_at"] = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
    payload["framework_path"] = str(framework)
    project_state = project / STATE_DIR_NAME
    project_state.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return True


def framework_template_values(framework: Path) -> dict[str, str]:
    return {
        "path": str(framework),
        "repo": git_output(framework, ["config", "--get", "remote.origin.url"], "local"),
        "version": git_output(framework, ["describe", "--tags", "--always"], "unknown"),
        "commit": git_output(framework, ["rev-parse", "HEAD"], "unknown"),
        "recorded_at": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    }


def render_framework_yaml_block(framework: Path) -> list[str]:
    values = framework_template_values(framework)
    return [
        "framework:",
        f'  path: "{values["path"]}"',
        f'  repo: "{values["repo"]}"',
        f'  version: "{values["version"]}"',
        f'  commit: "{values["commit"]}"',
        f'  recorded_at: "{values["recorded_at"]}"',
    ]


def rewrite_project_yaml_framework(project: Path, framework: Path, apply: bool) -> bool:
    path = project / "project.yaml"
    if not path.exists():
        return False
    lines = path.read_text(encoding="utf-8").splitlines()
    start = next((idx for idx, line in enumerate(lines) if line.strip() == "framework:" and not line.startswith(" ")), None)
    block = render_framework_yaml_block(framework)
    if start is None:
        new_lines = lines + ([""] if lines and lines[-1].strip() else []) + block
    else:
        end = start + 1
        while end < len(lines):
            line = lines[end]
            if line and not line.startswith((" ", "\t")) and not line.lstrip().startswith("#"):
                break
            end += 1
        new_lines = lines[:start] + block + lines[end:]
    changed = new_lines != lines
    if changed and apply:
        path.write_text("\n".join(new_lines) + "\n", encoding="utf-8")
    return changed


def is_legacy_aris_skill_target(target: str) -> bool:
    normalized = target.replace("\\", "/")
    if "/skills/" not in normalized:
        return False
    legacy_markers = [
        "/ARIS/",
        "/aris/",
        "Auto-research-in-sleep",
        "aris-orangmood-edition",
    ]
    return any(marker in normalized for marker in legacy_markers)


def find_legacy_aris_skill_links(project: Path) -> list[Path]:
    links: list[Path] = []
    for rel in [".claude/skills", ".agents/skills"]:
        root = project / rel
        if not root.is_dir():
            continue
        for path in sorted(root.iterdir()):
            if path.is_symlink() and is_legacy_aris_skill_target(os.readlink(path)):
                links.append(path)
    return links


def cmd_project_migrate_aris(args: argparse.Namespace) -> int:
    project = project_from_arg(args.path)
    framework = resolve_labline_repo(args)
    apply = bool(args.apply)
    legacy_manifest = project / LEGACY_STATE_DIR_NAME / "manifest.json"
    labline_manifest = project / STATE_DIR_NAME / "manifest.json"
    legacy_links = find_legacy_aris_skill_links(project)
    yaml_changed = rewrite_project_yaml_framework(project, framework, apply=False)

    print(f"project: {project}")
    print(f"framework: {framework}")
    print(f"mode: {'apply' if apply else 'dry-run'}")
    print(f"legacy_manifest: {'migrate' if legacy_manifest.exists() and not labline_manifest.exists() else 'skip'}")
    print(f"project_yaml.framework: {'update' if yaml_changed else 'ok'}")
    print(f"legacy_skill_links: {len(legacy_links)}")
    for link in legacy_links:
        print(f"  remove: {link.relative_to(project)} -> {os.readlink(link)}")

    if not apply:
        print("dry-run: rerun with --apply to modify files")
        return 0

    migrated = migrate_legacy_project_manifest(project, framework)
    for link in legacy_links:
        link.unlink()
    rewrite_project_yaml_framework(project, framework, apply=True)
    install_clients(project, framework)
    register_project(project)

    if migrated:
        print("applied: migrated .aris/manifest.json -> .labline/manifest.json")
    if legacy_links:
        print(f"applied: removed {len(legacy_links)} legacy ARIS skill links")
    if yaml_changed:
        print("applied: updated project.yaml framework block")
    print("applied: refreshed Labline clients")
    return 0


def init_project(args: argparse.Namespace, project: Path, name: str) -> None:
    project.mkdir(parents=True, exist_ok=True)
    ensure_dirs(project, args.size)
    write_gitignore(project)
    if not (project / ".git").exists():
        run(["git", "init"], cwd=project)
    framework = resolve_labline_repo(args)
    clients = install_clients(project, framework)
    repl = {
        "{PROJECT_NAME}": name,
        "{RESEARCH_DIRECTION}": args.direction,
        "{DATE}": datetime.now().strftime("%Y-%m-%d"),
        "{USER}": os.environ.get("USER", "unknown"),
        "{project-name}": name,
        "{FRAMEWORK_PATH}": str(framework),
        "{FRAMEWORK_REPO}": git_output(framework, ["config", "--get", "remote.origin.url"], "local"),
        "{FRAMEWORK_VERSION}": git_output(framework, ["describe", "--tags", "--always"], "unknown"),
        "{FRAMEWORK_COMMIT}": git_output(framework, ["rev-parse", "HEAD"], "unknown"),
        "{FRAMEWORK_RECORDED_AT}": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    }
    copy_text(framework / "templates" / "project.yaml.tmpl", project / "project.yaml", repl)
    copy_text(framework / "templates" / "AGENTS_MD_TEMPLATE.md", project / "AGENTS.md", repl)
    copy_text(framework / "templates" / "CLAUDE_MD_TEMPLATE.md", project / "CLAUDE.md", repl)
    write_manifest(project, name, args.direction, clients)
    register_project(project)
    if args.no_commit:
        return
    if git_has_commits(project):
        return
    status = run(["git", "status", "--porcelain"], cwd=project)
    if status.stdout:
        run(["git", "add", "-A"], cwd=project)
        run(["git", "-c", "user.name=Labline CLI", "-c", "user.email=lane@example.invalid", "commit", "-m", f"init: {name} ({args.direction})"], cwd=project)


def cmd_project_init(args: argparse.Namespace) -> int:
    project = Path(args.path).expanduser().resolve()
    name = args.project_name or project.name
    init_project(args, project, name)
    return 0


def cmd_project_doctor(args: argparse.Namespace) -> int:
    project = project_from_arg(args.path)
    framework = resolve_labline_repo(args)
    checks = []
    checks.append(("project.yaml", (project / "project.yaml").exists()))
    checks.append(("AGENTS.md", (project / "AGENTS.md").exists()))
    checks.append(("CLAUDE.md", (project / "CLAUDE.md").exists()))
    checks.append((".labline", (project / STATE_DIR_NAME).exists()))
    checks.append(("framework", framework.exists()))
    yaml_text = (project / "project.yaml").read_text(encoding="utf-8") if (project / "project.yaml").exists() else ""
    checks.append(("project.yaml.schema_version", yaml_text.count("schema_version:") == 1))
    checks.append(("project.yaml.framework.path", f'path: "{framework}"' in yaml_text))
    checks.append((".labline.manifest", (project / STATE_DIR_NAME / "manifest.json").exists()))
    if (project / LEGACY_STATE_DIR_NAME / "manifest.json").exists() and not (project / STATE_DIR_NAME / "manifest.json").exists():
        checks.append((".aris.legacy_manifest", True))
    checks.append((".claude.skills", (project / ".claude" / "skills").exists() or not (project / ".claude").exists()))
    checks.append((".agents.skills", (project / ".agents" / "skills").exists() or not (project / ".agents").exists()))
    status = 0
    for key, ok in checks:
        print(f"{key}: {'ok' if ok else 'missing' if key != 'project.yaml.schema_version' else 'duplicate'}")
        if not ok:
            status = 1
    return status


def cmd_project_update(args: argparse.Namespace) -> int:
    project = project_from_arg(args.path)
    framework = resolve_labline_repo(args)
    migrated = migrate_legacy_project_manifest(project, framework)
    install_clients(project, framework)
    register_project(project)
    if migrated:
        print("legacy: migrated .aris/manifest.json -> .labline/manifest.json")
    return 0


def cmd_project_detach(args: argparse.Namespace) -> int:
    project = project_from_arg(args.path)
    framework = resolve_labline_repo(args)
    uninstallers = [
        (project / STATE_DIR_NAME / "installed-skills.txt", framework / "tools" / "install_labline.sh"),
        (project / STATE_DIR_NAME / "installed-skills-codex.txt", framework / "tools" / "install_labline_codex.sh"),
    ]
    for manifest, installer in uninstallers:
        if manifest.exists() and installer.exists():
            run(["bash", str(installer), str(project), "--labline-repo", str(framework), "--quiet", "--uninstall"])
    for rel in [f"{STATE_DIR_NAME}/manifest.json", f"{STATE_DIR_NAME}/installed-skills.txt", f"{STATE_DIR_NAME}/installed-skills-codex.txt"]:
        path = project / rel
        if path.exists():
            path.unlink()
    unregister_project(project)
    return 0


