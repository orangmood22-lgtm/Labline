def load_dev_runtime_config(init: bool = False) -> dict:
    path = dev_runtime_config_path()
    if not path.exists():
        data = default_dev_runtime_config()
        if init:
            save_dev_runtime_config(data)
        return data
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        data = default_dev_runtime_config()
    data.setdefault("schema_version", 1)
    data.setdefault("defaults", {})
    data["defaults"].setdefault("provider", "codex_subagent")
    data["defaults"].setdefault("transport", "codex_subagent")
    data["defaults"].setdefault("model", "gpt-5.4-mini")
    data["defaults"].setdefault("reasoning_effort", "medium")
    data.setdefault("providers", {})
    data["providers"].setdefault("codex_subagent", default_dev_runtime_config()["providers"]["codex_subagent"])
    data.setdefault("roles", {})
    for role_name, role_spec in default_dev_runtime_config()["roles"].items():
        data["roles"].setdefault(role_name, role_spec)
    if init:
        save_dev_runtime_config(data)
    return data


def save_dev_runtime_config(data: dict) -> None:
