def upsert_runtime_provider(data: dict, name: str, spec: dict) -> dict:
    providers = data.setdefault("providers", {})
    providers[name] = {k: v for k, v in spec.items() if v is not None}
    return providers[name]


def resolve_runtime_provider(data: dict, provider_name: str | None, role: dict, defaults: dict) -> tuple[str, dict]:
    selected = provider_name or role.get("provider") or defaults.get("provider") or "codex_subagent"
    providers = data.get("providers", {})
    base = dict(providers.get(selected, {}))
    if not base:
        base = {
            "transport": role.get("transport") or defaults.get("transport", "codex_subagent"),
            "model": role.get("model") or defaults.get("model", "gpt-5.4-mini"),
        }
    base.setdefault("transport", role.get("transport") or defaults.get("transport", "codex_subagent"))
    base.setdefault("model", role.get("model") or defaults.get("model", "gpt-5.4-mini"))
    return selected, base


