                "--quiet",
            ],
            cwd=working_project,
            env=env,
            checks=checks,
        )
        heartbeat_payload = json.loads(heartbeat_result.stdout)
        if heartbeat_payload.get("action_counts", {}).get("healthy", 0) < 1:
            checks[-1]["status"] = "fail"
            checks[-1]["details"]["reason"] = "healthy heartbeat action missing"
            raise RuntimeError("heartbeat did not record a healthy check")

        archive_result = run_debug_subprocess(
            "remote_archive_message",
            [
                sys.executable,
                str(remote_observation),
                "--state-root",
                str(bridge_state),
                "archive-message",
                "--profile",
                "labline-debug",
                "--workspace",
                "debug-workspace",
                "--chat-id",
                "oc_debug_secret",
                "--sender-open-id",
                "ou_debug_secret",
                "--message-id",
                "om_debug_001",
                "--text",
                "现在怎么样了",
                "--now",
                now,
            ],
            cwd=working_project,
            env=env,
            checks=checks,
        )
        archive_ref = json.loads(archive_result.stdout)["archive_ref"]
        route_result = run_debug_subprocess(
            "remote_observation_route",
            [
                sys.executable,
                str(remote_observation),
                "--state-root",
                str(bridge_state),
                "route-message",
                "--project",
                str(working_project),
                "--profile",
                "labline-debug",
                "--workspace",
                "debug-workspace",
                "--archive-ref",
                archive_ref,
                "--chat-id",
                "oc_debug_secret",
                "--sender-open-id",
                "ou_debug_secret",
                "--text",
                "现在怎么样了",
                "--now",
                now,
            ],
            cwd=working_project,
            env=env,
            checks=checks,
        )
        route_payload = json.loads(route_result.stdout)
        checks[-1]["details"]["route"] = route_payload.get("route")
        checks[-1]["details"]["inject_tui"] = route_payload.get("inject_tui")
        if route_payload.get("route") != "observation" or route_payload.get("inject_tui") is not False:
            checks[-1]["status"] = "fail"
            raise RuntimeError("remote message did not route to observation")

        runtime_text = runtime_tree_text(working_project)
        leaked = [value for value in ["oc_debug_secret", "ou_debug_secret", "现在怎么样了"] if value in runtime_text]
        append_debug_check(checks, "no_remote_identity_leak", "pass" if not leaked else "fail", {"leaked": leaked})
        if leaked:
            raise RuntimeError("remote identity or text leaked into project runtime")

        report["status"] = "pass"
    except Exception as exc:
        if not any(check.get("status") == "fail" for check in checks):
            append_debug_check(checks, "internal_error", "fail", {"error": str(exc)})
        report["status"] = "fail"
        report["error"] = str(exc)
    finally:
        write_runtime_smoke_reports(report, report_dir)

    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        print(f"status: {report['status']}")
        print(f"report: {report['report_md']}")
        print(f"json: {report['report_json']}")
        print(f"working_project: {report['working_project']}")
    return 0 if report["status"] == "pass" else 1


