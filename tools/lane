def cmd_dev_runtime_load(args: argparse.Namespace) -> int:
    env_file = Path(args.env_file).expanduser().resolve()
    values = parse_dotenv(env_file)
    role_name = dotenv_get(values, "agent", "agent_name", "LABLINE_AGENT", "LABLINE_AGENT_NAME")
    provider_name = dotenv_get(values, "provider", "provider_name", "LABLINE_PROVIDER", "LABLINE_PROVIDER_NAME")
    base_url = dotenv_get(values, "base_url", "LABLINE_BASE_URL")
    model = dotenv_get(values, "model_name", "model", "LABLINE_MODEL_NAME", "LABLINE_MODEL")
    transport = dotenv_get(values, "transport", "LABLINE_TRANSPORT") or "openai_compatible"
    api_key = dotenv_get(values, "api_key", "LABLINE_API_KEY")
    api_key_env = dotenv_get(values, "api_key_env", "LABLINE_API_KEY_ENV") or runtime_provider_api_key_env(provider_name)

    missing = []
    for key, value in [
        ("agent", role_name),
        ("provider", provider_name),
        ("base_url", base_url),
        ("model_name", model),
    ]:
        if not value:
            missing.append(key)
    if not api_key and not api_key_env:
        missing.append("api_key or api_key_env")
    if missing:
        raise SystemExit(f"missing required env fields: {', '.join(missing)}")

    data = load_dev_runtime_config(init=True)
    provider = upsert_runtime_provider(
        data,
        provider_name,
        {
            "transport": transport,
            "model": model,
            "base_url": base_url,
            "api_key_env": api_key_env,
        },
    )
    role = data.setdefault("roles", {}).setdefault(role_name, {})
    role["provider"] = provider_name
    role["transport"] = provider.get("transport", transport)
    role["model"] = provider.get("model", model)
    save_dev_runtime_config(data)

    secret_file = ""
    if api_key:
        secrets = parse_dotenv(dev_runtime_env_path()) if dev_runtime_env_path().exists() else {}
        secrets[api_key_env] = api_key
        write_dotenv(dev_runtime_env_path(), secrets)
        secret_file = str(dev_runtime_env_path())

    print(f"agent: {role_name}")
    print(f"provider: {provider_name}")
    print(f"transport: {transport}")
    print(f"model: {model}")
    print(f"base_url: {base_url}")
    print(f"api_key_env: {api_key_env}")
    if secret_file:
        print(f"secret_file: {secret_file}")
    return 0


def resolve_runtime_task(args: argparse.Namespace) -> tuple[str, Path | None]:
    if args.task and args.task_file:
        raise SystemExit("choose either task or --task-file, not both")
    if args.task_file:
        task_path = Path(args.task_file).expanduser().resolve()
        if not task_path.exists():
            raise SystemExit(f"task file not found: {task_path}")
        return task_path.read_text(encoding="utf-8"), task_path
    if args.task:
        return args.task, None
    raise SystemExit("missing task or --task-file")


def runtime_system_guardrails(
    role: str,
    provider: str,
    transport: str,
    model: str,
    base_url: str | None,
    api_key_env: str | None,
    effort: str | None,
    role_spec: dict | None = None,
) -> str:
    role_scope = format_runtime_role_scope(role_spec or {})
    return f"""# Labline Dev Runtime Guardrails

role: {role}
provider: {provider}
transport: {transport}
model: {model}
base_url: {base_url or '<none>'}
api_key_env: {api_key_env or '<none>'}
reasoning_effort: {effort or '<none>'}

## Rules

- Stay inside the declared task.
- Do not apply patches automatically.
- Do not commit changes automatically.
- Do not promote or release anything automatically.
- Do not handle credentials, private keys, or secrets.
- Do not log API key values.
- Report concrete files, commands, and results.

{role_scope}
"""


def format_runtime_role_scope(role: dict) -> str:
    allowed = role.get("allowed_work") or []
    forbidden = role.get("forbidden_work") or []
    lines = ["## Role Scope", ""]
    if allowed:
        lines.append("Allowed work:")
        lines.extend(f"- {item}" for item in allowed)
        lines.append("")
    if forbidden:
        lines.append("Forbidden work:")
        lines.extend(f"- {item}" for item in forbidden)
        lines.append("")
    return "\n".join(lines).rstrip()


def render_runtime_task_prompt(
    role_name: str,
    task: str,
    provider_name: str,
    transport: str,
    model: str,
    base_url: str | None,
    api_key_env: str | None,
    effort: str | None,
    role: dict,
    files: list[str],
    extra_sections: list[str] | None = None,
) -> str:
    file_lines = "\n".join(f"- {item}" for item in files) if files else "- [not specified; ask leader before editing]"
    extras = "\n\n".join(section.rstrip() for section in (extra_sections or []) if section.strip())
    extra_block = f"\n\n{extras}" if extras else ""
    return f"""# Labline Dev Runtime Task

created_at: {utc_stamp()}
role: {role_name}
provider: {provider_name}
transport: {transport}
model: {model}
base_url: {base_url or '<none>'}
api_key_env: {api_key_env or '<none>'}
reasoning_effort: {effort}

## Task

{task}

## Write Scope

{file_lines}

{format_runtime_role_scope(role)}{extra_block}

## Operating Rules

- You are not alone in the codebase. Do not revert unrelated user or agent changes.
- Stay inside the declared write scope. If the task requires another file, report it instead of editing silently.
- Prefer producing a small patch, test draft, doc draft, reference sweep, or concrete finding list.
- Do not make final architecture, release, promote, or rollback decisions.
- Do not run destructive git commands.
- Do not handle credentials, private keys, or secrets.
- Never log, print, or persist API key values; only record the environment variable name.
- Report changed files and verification commands.
"""


def openai_compatible_chat_completion(base_url: str, api_key: str, model: str, messages: list[dict], timeout: int) -> dict:
    endpoint = base_url.rstrip("/") + "/chat/completions"
    payload = json.dumps({"model": model, "messages": messages}).encode("utf-8")
    request = urllib.request.Request(
        endpoint,
        data=payload,
        method="POST",
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {api_key}",
        },
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            body = response.read().decode("utf-8")
            return json.loads(body)
    except urllib.error.HTTPError as exc:
        detail = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"openai-compatible request failed: HTTP {exc.code}: {detail}") from exc
    except urllib.error.URLError as exc:
        raise RuntimeError(f"openai-compatible request failed: {exc.reason}") from exc


def write_runtime_run_artifacts(run_dir: Path, task_text: str, request_payload: dict, response_text: str, metadata: dict) -> None:
    run_dir.mkdir(parents=True, exist_ok=False)
    (run_dir / "task.md").write_text(task_text, encoding="utf-8")
    (run_dir / "request.json").write_text(json.dumps(request_payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    (run_dir / "response.md").write_text(response_text, encoding="utf-8")
    (run_dir / "metadata.json").write_text(json.dumps(metadata, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


