def cmd_dev_runtime_run(args: argparse.Namespace) -> int:
    framework = resolve_labline_repo(args)
    data = load_dev_runtime_config(init=True)
    defaults = data["defaults"]
    role = data.get("roles", {}).get(args.role, data["roles"].get("dev-worker", {}))
    provider_name, provider = resolve_runtime_provider(data, args.provider, role, defaults)
    transport = args.transport or provider.get("transport") or role.get("transport") or defaults.get("transport", "codex_subagent")
    model = args.model or provider.get("model") or role.get("model") or defaults.get("model", "gpt-5.4-mini")
    base_url = args.base_url or provider.get("base_url")
    api_key_env = args.api_key_env or provider.get("api_key_env")
    effort = args.reasoning_effort or role.get("reasoning_effort") or defaults.get("reasoning_effort", "medium")
    task_text, task_path = resolve_runtime_task(args)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    slug_source = task_path.name if task_path else task_text
    run_dir = dev_runtime_log_root(framework, args.role) / f"{stamp}-{slug_from_text(slug_source)}"

    if transport == "codex_subagent":
        raise SystemExit("transport codex_subagent is executed by the current Codex session's subagent tool, not by the CLI runner")
    if transport != "openai_compatible":
        raise SystemExit(f"unsupported worker transport: {transport}")
    if not base_url:
        raise SystemExit("missing base_url for openai_compatible provider")
    if not api_key_env:
        raise SystemExit("missing api_key_env for openai_compatible provider")
    api_key = runtime_api_key(api_key_env)
    if not api_key:
        raise SystemExit(f"missing API key environment variable: {api_key_env}")

    system_prompt = runtime_system_guardrails(args.role, provider_name, transport, model, base_url, api_key_env, effort, role)
    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": task_text},
    ]
    request_payload = {"model": model, "messages": messages}
    response = openai_compatible_chat_completion(base_url, api_key, model, messages, timeout=args.timeout)
    response_text = json.dumps(response, ensure_ascii=False, indent=2)
    choice_text = ""
    choices = response.get("choices") or []
    if choices:
        message = choices[0].get("message") or {}
        choice_text = message.get("content") or ""
    metadata = {
        "schema_version": 1,
        "timestamp": utc_stamp(),
        "provider": provider_name,
        "transport": transport,
        "model": model,
        "base_url": base_url,
        "api_key_env": api_key_env,
        "timeout": args.timeout,
        "task_file": str(task_path) if task_path else "",
        "response_file": str(run_dir / "response.md"),
    }
    write_runtime_run_artifacts(run_dir, task_text, request_payload, choice_text or response_text, metadata)
    print(f"run_dir: {run_dir}")
    print(f"provider: {provider_name}")
    print(f"model: {model}")
    print(f"response_file: {run_dir / 'response.md'}")
    return 0


def resolve_dev_workflow_dir(framework: Path, value: str) -> Path:
    candidate = Path(value).expanduser()
    if candidate.exists():
        return candidate.resolve()
    root = dev_workflow_log_root(framework)
    named = root / value
    if named.exists():
        return named.resolve()
    raise SystemExit(f"dev workflow not found: {value}")


def load_dev_workflow(workflow_dir: Path) -> dict:
    manifest = workflow_dir / "workflow.json"
    if not manifest.exists():
        raise SystemExit(f"missing workflow manifest: {manifest}")
    try:
        data = json.loads(manifest.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid workflow manifest: {manifest}") from exc
    if not isinstance(data, dict):
        raise SystemExit(f"invalid workflow manifest: {manifest}")
    return data


def save_dev_workflow(workflow_dir: Path, data: dict) -> None:
    (workflow_dir / "workflow.json").write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def dev_workflow_next_check(interval: str) -> str:
    return utc_stamp(utc_now() + parse_duration(interval))


