            raise RuntimeError("long task process failed")
        if not result_path.exists():
            checks[-1]["status"] = "fail"
            checks[-1]["details"]["reason"] = "result missing"
            raise RuntimeError("long task result missing")

        run_debug_subprocess(
            "runtime_task_complete",
            [
                sys.executable,
                str(lane_bin),
                "runtime",
                "task",
                "complete",
                task_id,
                "--project",
                str(working_project),
                "--labline-repo",
                str(framework),
                "--quiet",
                "--artifact",
                str(result_path.relative_to(working_project)),
            ],
            cwd=working_project,
            env=env,
            checks=checks,
        )

        now_terminal = args.now_terminal or datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
        terminal_hb = run_debug_subprocess(
            "heartbeat_terminal",
            [
                sys.executable,
                str(lane_bin),
                "heartbeat",
                "--project",
                str(working_project),
                "--task",
                task_id,
                "--now",
                now_terminal,
                "--labline-repo",
                str(framework),
                "--quiet",
            ],
            cwd=working_project,
            env=env,
            checks=checks,
        )
        terminal_payload = json.loads(terminal_hb.stdout)
        escalated = terminal_payload.get("action_counts", {}).get("escalated", 0)
        checks[-1]["details"]["escalated"] = escalated
        if escalated < 1:
            checks[-1]["status"] = "fail"
            raise RuntimeError("terminal heartbeat did not escalate")

        report["status"] = "pass"
    except Exception as exc:
        if process and process.poll() is None:
            process.kill()
            process.wait(timeout=5)
        if not any(check.get("status") == "fail" for check in checks):
            append_debug_check(checks, "internal_error", "fail", {"error": str(exc)})
        report["status"] = "fail"
        report["error"] = str(exc)
    finally:
        write_runtime_smoke_reports(report, report_dir)

    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        print(f"status: {report['status']}")
        print(f"report: {report['report_md']}")
        print(f"json: {report['report_json']}")
        print(f"working_project: {report['working_project']}")
    return 0 if report["status"] == "pass" else 1


def notify_framework_update_once_per_day(framework: Path, data: dict, returncode: int = 0) -> int:
    if data.get("status") != "update available":
        return returncode
    if is_recent(data.get("last_notified_at"), timedelta(days=1)):
        return returncode

    local = data.get("local_commit", "unknown")[:7]
    remote = data.get("upstream_commit", "unknown")[:7]
    print(f"[Labline] framework update available: local {local} -> upstream {remote}")
    print("       run: lane framework update")
    print("       rollback: lane framework rollback")
    data["last_notified_at"] = utc_stamp()
    save_framework_update_status(framework, data)
    return returncode


def cmd_framework_update(args: argparse.Namespace) -> int:
    framework = resolve_labline_repo(args)
    before = record_previous_commit(framework)
    result = run(["git", "pull", "--ff-only"], cwd=framework, check=False)
    after = git_output(framework, ["rev-parse", "HEAD"], "unknown")
    if result.returncode != 0:
        # A local-only test repo has no remote; still record history and continue.
        if "There is no tracking information" not in result.stderr and "No remote repository" not in result.stderr:
            print(result.stderr.strip())
            return result.returncode
    print(f"framework: {before[:7]} -> {after[:7]}")
    if args.no_project_sync:
        print("project sync: skipped")
        return 0
    updated, missing = sync_registered_projects(args, framework)
    msg = f"project sync: {updated} updated"
    if missing:
        msg += f", {missing} missing"
    print(msg)
    return 0


def cmd_framework_rollback(args: argparse.Namespace) -> int:
    framework = resolve_labline_repo(args)
    prev = previous_commit()
    if not prev:
        print("no rollback commit recorded")
        return 1
    current = git_output(framework, ["rev-parse", "HEAD"], "unknown")
    run(["git", "reset", "--hard", prev], cwd=framework)
    print(f"framework rollback: {current[:7]} -> {prev[:7]}")
    if args.no_project_sync:
        print("project sync: skipped")
        return 0
    updated, missing = sync_registered_projects(args, framework)
    msg = f"project sync: {updated} updated"
    if missing:
        msg += f", {missing} missing"
    print(msg)
    return 0


