def append_debug_check(checks: list[dict], name: str, status: str, details: dict | None = None) -> None:
    checks.append({"name": name, "status": status, "details": details or {}})


def run_debug_subprocess(name: str, cmd: list[str], cwd: Path, env: dict[str, str], checks: list[dict]) -> subprocess.CompletedProcess:
    result = subprocess.run(cmd, cwd=str(cwd), capture_output=True, text=True, env=env)
    details = {
        "cmd": cmd,
        "returncode": result.returncode,
        "stdout": limit_debug_text(result.stdout),
        "stderr": limit_debug_text(result.stderr),
    }
    append_debug_check(checks, name, "pass" if result.returncode == 0 else "fail", details)
    if result.returncode != 0:
        raise RuntimeError(f"{name} failed")
    return result


def runtime_tree_text(project: Path) -> str:
    root = project / STATE_DIR_NAME / "runtime"
    if not root.exists():
        return ""
    chunks = []
    for path in sorted(root.rglob("*")):
        if path.is_file():
            chunks.append(path.read_text(encoding="utf-8", errors="replace"))
    return "\n".join(chunks)


def write_runtime_smoke_reports(report: dict, report_dir: Path) -> tuple[Path, Path]:
    report_json = report_dir / "debug-report.json"
    report_md = report_dir / "debug-report.md"
    report["report_json"] = str(report_json)
    report["report_md"] = str(report_md)
    report_json.write_text(json.dumps(report, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    lines = [
        "# Labline Runtime Smoke Report",
        "",
        f"status: {report['status']}",
        f"source_project: {report['source_project']}",
        f"working_project: {report['working_project']}",
        f"in_place: {str(report['in_place']).lower()}",
        "",
        "| check | status |",
        "|---|---|",
    ]
    for check in report["checks"]:
        lines.append(f"| {check['name']} | {check['status']} |")
    report_md.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return report_json, report_md


def debug_longtask_inline_script() -> str:
    return textwrap.dedent(
        """
        from __future__ import annotations

        import json
        import os
        import sys
        import time
        from datetime import datetime, timezone
        from pathlib import Path

        def utc_now() -> str:
            return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")

        def write_json(path: Path, payload: dict) -> None:
            path.parent.mkdir(parents=True, exist_ok=True)
            tmp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
            tmp.write_text(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True) + "\\n", encoding="utf-8")
            tmp.replace(path)

        seconds = int(sys.argv[1])
        out_dir = Path(sys.argv[2])
        interval = float(sys.argv[3])
        out_dir.mkdir(parents=True, exist_ok=True)
        progress_path = out_dir / "progress.json"
        result_path = out_dir / "result.json"
        started_at = utc_now()
        deadline = time.monotonic() + seconds
        step = 0
        while True:
            remaining = max(0.0, deadline - time.monotonic())
            write_json(
                progress_path,
                {
                    "status": "running" if remaining > 0 else "completed",
                    "pid": os.getpid(),
                    "step": step,
                    "started_at": started_at,
                    "updated_at": utc_now(),
                    "target_seconds": seconds,
                    "result_path": str(result_path),
                },
            )
            print(f"[debug-longtask] step={step} remaining={remaining:.1f}s", flush=True)
            if remaining <= 0:
                break
            step += 1
            time.sleep(min(interval, remaining))
        write_json(
            result_path,
            {
                "status": "completed",
                "pid": os.getpid(),
                "started_at": started_at,
                "completed_at": utc_now(),
                "target_seconds": seconds,
                "steps": step + 1,
            },
        )
        print(f"[debug-longtask] completed result={result_path}", flush=True)
        """
    )


def cmd_debug_runtime_smoke(args: argparse.Namespace) -> int:
