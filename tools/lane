def runtime_binding_for_role(data: dict, role_name: str) -> tuple[dict, str, dict, str, str, str | None, str | None, str | None]:
    defaults = data["defaults"]
    roles = data.get("roles", {})
    if role_name not in roles:
        raise SystemExit(f"unknown dev runtime role: {role_name}")
