                "--kind",
                "debug",
                "--title",
                "debug runtime smoke task",
                "--execution-mode",
                "agent_turn",
                "--durability",
                "resumable",
                "--observation",
                "enabled",
                "--heartbeat",
                "passive",
                "--status",
                "running",
                "--next-expected-update",
                "1970-01-01T00:00:00Z",
            ],
