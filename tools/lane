def load_labline_runtime():
    path = REPO_ROOT / "tools" / "labline_runtime.py"
    spec = importlib.util.spec_from_file_location("labline_runtime", path)
    if spec is None or spec.loader is None:
        raise SystemExit(f"cannot load runtime helper: {path}")
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


def limit_debug_text(value: str, limit: int = 4000) -> str:
    if len(value) <= limit:
        return value
    return value[:limit] + "\n...<truncated>"


